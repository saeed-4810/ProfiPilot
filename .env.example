# Root-level environment template — copy to .env and fill in values.
# Never commit .env files. Workspace-specific vars live in apps/backend/.env.example
# and apps/frontend/.env.local.example.

# --- CI / deployment context ---
# NODE_ENV=development | staging | production
NODE_ENV=development

# --- Package manager config ---
# Set by CI automatically; listed here for reference.
# PNPM_HOME=/usr/local/pnpm-global
