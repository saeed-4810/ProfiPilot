# Backend environment template — copy to .env and fill in real values.
# NEVER commit .env files. Only .env.example belongs in source control.
# See CONTRIBUTING.md for the secrets policy.

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Firebase Admin SDK ---
# Required: your Firebase project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Optional: service account JSON string (for local dev without ADC).
# In staging/production, use Application Default Credentials (ADC) instead.
# Format: the full JSON content of the service account key, as a single line string.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# --- PageSpeed Insights API (ADR-012) ---
# Optional: Google PSI API key for quota monitoring. Works without key at reduced quota.
# Get a key: https://developers.google.com/speed/docs/insights/v5/get-started
# PAGESPEED_API_KEY=your-psi-api-key

# --- Observability ---
# LOG_LEVEL=info
