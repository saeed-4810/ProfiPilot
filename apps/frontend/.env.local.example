# Frontend environment template — copy to .env.local and fill in real values.
# NEVER commit .env.local. Only .env.local.example belongs in source control.
# See CONTRIBUTING.md for the secrets policy.

# --- API ---
# Leave empty for local dev — Next.js rewrites in next.config.mjs proxy
# API routes (/auth/*, /audits/*, /api/v1/*, /health) to the backend.
# This keeps frontend and backend on the same origin so cookies work.
# Staging/production: also empty (Firebase Hosting handles rewrites).
NEXT_PUBLIC_API_BASE_URL=

# --- E2E Test Credentials ---
# Firebase test account for authenticated E2E tests (Playwright).
# Create a test user in Firebase Console → Authentication → Users.
# E2E_TEST_EMAIL=test@example.com
# E2E_TEST_PASSWORD=your-test-password

# --- Firebase Client SDK (public config — safe to expose in the browser bundle) ---
# Obtain from: Firebase Console → prefpilot-dev → Project settings → Your apps → Web app SDK config
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# --- PostHog Analytics (PERF-122) ---
# PostHog EU Cloud (free tier, cookieless mode).
# Obtain from: PostHog → Project Settings → Project API Key
# T-PERF-122-008: API key loaded from env var, never hardcoded.
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
