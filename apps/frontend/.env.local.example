# Frontend environment template — copy to .env.local and fill in real values.
# NEVER commit .env.local. Only .env.local.example belongs in source control.
# See CONTRIBUTING.md for the secrets policy.

# --- API ---
# Base URL of the backend service (no trailing slash).
# Local: http://localhost:3001
# Staging/production: Cloud Run service URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

