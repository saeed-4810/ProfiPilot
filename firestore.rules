rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── Default Deny ───────────────────────────────────────────────────
    // Firestore is deny-by-default, but we make it explicit per ADR-004.
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Projects Collection ────────────────────────────────────────────
    // Read/write only by authenticated user where ownerId == request.auth.uid.
    match /projects/{projectId} {
      allow read: if isAuthenticated()
                  && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated()
                            && resource.data.ownerId == request.auth.uid;

      // URLs subcollection — inherits project ownership check.
      match /urls/{urlId} {
        allow read: if isAuthenticated()
                    && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
        allow create: if isAuthenticated()
                      && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
        allow update, delete: if isAuthenticated()
                              && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }

    // ─── Audits Collection ──────────────────────────────────────────────
    // Read only by owner (uid match); write only by backend (Admin SDK).
    // Admin SDK bypasses rules entirely, so write: if false is correct.
    match /audits/{auditId} {
      allow read: if isAuthenticated()
                  && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ─── Recommendations Collection ─────────────────────────────────────
    // Read only by audit owner; write only by backend (Admin SDK).
    match /recommendations/{recommendationId} {
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data.uid == request.auth.uid;
      allow write: if false;
    }

    // ─── Summaries Collection ───────────────────────────────────────────
    // Read only by audit owner; write only by backend (Admin SDK).
    match /summaries/{summaryId} {
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data.uid == request.auth.uid;
      allow write: if false;
    }

    // ─── Exports Collection ─────────────────────────────────────────────
    // Read only by owner; write only by backend (Admin SDK).
    match /exports/{exportId} {
      allow read: if isAuthenticated()
                  && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ─── Feedback Collection (PERF-141) ─────────────────────────────────
    // Create-only for authenticated user matching userId. No client reads.
    // All reads are via Admin SDK (backend/Cloud Functions only).
    match /feedback/{docId} {
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow read: if false;
    }

    // ─── Feedback Preferences Collection (PERF-141) ─────────────────────
    // Read/write for authenticated user matching own userId (doc ID = userId).
    match /feedback_preferences/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
